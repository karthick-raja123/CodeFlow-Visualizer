# ============================================
# CodeFlow Visualizer Environment Variables
# ============================================
# Copy this file to .env and configure for your environment

# ============================================
# FRONTEND CONFIGURATION (Vite Build)
# ============================================

# API Base URL for frontend to communicate with backend
# Local Development: http://localhost:8000 (backend on port 8000)
# Vercel Serverless: /api (routes to Vercel serverless function)
# Remote Backend: https://your-render-backend.onrender.com
VITE_API_URL=http://localhost:8000

# Optional: API prefix for routing
# Use /api for Vercel serverless, empty string for remote backend
VITE_API_PREFIX=

# Request timeout in milliseconds (default: 10000)
VITE_API_TIMEOUT=10000

# Enable session management (future feature)
VITE_ENABLE_SESSIONS=false

# ============================================
# BACKEND CONFIGURATION
# ============================================

# FastAPI host and port
FASTAPI_HOST=127.0.0.1
FASTAPI_PORT=8000

# Allowed origins for CORS (comma-separated)
# Local: http://localhost:5173,http://localhost:3000
# Production: https://your-frontend.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# APPLICATION ENVIRONMENT
# ============================================

# Environment: development, staging, production
APP_ENV=development

# Enable debug logging
DEBUG=true

# ============================================
# DEPLOYMENT (Uncomment for production deployment)
# ============================================

# For Render backend deployment:
# VITE_API_URL=https://your-codeflow-api.onrender.com
# ALLOWED_ORIGINS=https://your-codeflow.vercel.app
# APP_ENV=production
# DEBUG=false
